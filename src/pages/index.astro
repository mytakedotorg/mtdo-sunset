---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { parseMinute, formatDate } from "../lib/minutes";

const entries = await getCollection("minutes");
const minutes = entries
  .map((e) => parseMinute(e))
  .sort((a, b) => (b.date?.getTime() ?? 0) - (a.date?.getTime() ?? 0));
---

<Base
  title="MyTake.org — Sunset"
  description="MyTake.org is shutting down. Archive of board minutes from the 501(c)(3) non-profit."
>
  <h1>MyTake.org is shutting down.</h1>
  <p class="lede">
    Our website is offline. The 501(c)(3) corporation is winding down over the
    coming year. This page preserves the board minutes for the public record.
  </p>

  <div class="banner">
    <strong>Status:</strong> wind-down in progress. Final dissolution expected
    around mid-2027.
  </div>

  <aside class="for-sale">
    <h2>The mytake.org domain is for sale</h2>
    <p>
      As part of the wind-down, we're transferring the <code>mytake.org</code>
      domain to a new owner.
    </p>
    <p>
      <a
        class="cta"
        href="https://www.afternic.com/forsale/mytake.org"
        rel="external"
      >
        Buy the domain →
      </a>
    </p>
  </aside>

  <h2>Documents</h2>
  <p>
    As a 501(c)(3) public charity, we make our governance and financial
    documents available for public inspection.
  </p>

  <h3>Governance</h3>
  <ul class="docs">
    <li>
      <a href="https://drive.google.com/file/d/1uE02CoUHepQ8_8R3EhmPVXnvKARvfvIe/view?usp=drive_link" rel="external">
        Articles of Incorporation
      </a>
    </li>
    <li>
      <a href="https://drive.google.com/file/d/1WAVju9piI0CfZ8lTpkY8seGz6l_lacLM/view?usp=drive_link" rel="external">
        Bylaws
      </a>
    </li>
    <li>
      <a href="https://drive.google.com/file/d/1N82xZgWBjLR3tT6vHD4M495tsVyJ4JyG/view?usp=drive_link" rel="external">
        Conflict of Interest Policy
      </a>
    </li>
  </ul>

  <h3>Financials & IRS filings</h3>
  <ul class="docs">
    <li>
      <a href="https://drive.google.com/file/d/1zuZYXIpH9BM-n3uDwW3aQkR8JZWh1n4c/view?usp=drive_link" rel="external">
        IRS determination letter
      </a>
    </li>
    <li>
      <a href="https://drive.google.com/drive/folders/18NelKJFP3KMb0Tk8KfhSRnfwqafPUmk6" rel="external">
        Form 990 filings
      </a>
    </li>
    <li>
      <a href="https://docs.google.com/spreadsheets/d/1SZtK9ajcQAs8la1dqnHtc9yAWJK7j-26HBrAx-gtUDY/edit?gid=1674413579#gid=1674413579" rel="external">
        Budget &amp; every financial transaction
      </a>
    </li>
  </ul>

  <h2>Board minutes</h2>
  <ul class="minutes">
    {
      minutes.map((m) => (
        <li>
          <a href={`/minutes/${m.slug}/`}>{m.title}</a>
          <time datetime={m.date?.toISOString()}>{formatDate(m.date)}</time>
        </li>
      ))
    }
  </ul>
</Base>
